{
  "name": "datenight",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-404.cjs",
    "build:dev": "vite build --mode development",
    "build:gh-pages": "cross-env BASE_PATH=/Date-Night/ vite build && node scripts/copy-404.cjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest run --config tests/vitest.config.ts --coverage",
    "test:ui": "vitest --config tests/vitest.config.ts --ui",
    "test:unit": "vitest run --config tests/vitest.config.ts --project unit",
    "test:integration": "vitest run --config tests/vitest.config.ts --project integration",
    "test:api": "vitest run --config tests/vitest.config.ts --project api",
    "test:smoke": "vitest run --config tests/vitest.config.ts --project smoke",
    "test:unit:coverage": "vitest run --config tests/vitest.config.ts --project unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:setup": "playwright test --project=setup",
    "test:e2e:smoke": "playwright test --project=smoke --project=setup",
    "test:e2e:user-journeys": "playwright test --project=user-journeys-desktop",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:accessibility": "playwright test --project=accessibility",
    "test:e2e:performance": "playwright test --project=performance",
    "test:e2e:regression": "playwright test --project=regression",
    "test:e2e:security": "playwright test --project=security",
    "test:e2e:error-boundary": "playwright test --project=error-boundary",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:tablet": "playwright test --project=tablet",
    "test:all": "concurrently -k -n vitest,playwright \"npm run test\" \"npm run test:e2e\"",
    "playwright:install": "playwright install --with-deps chromium firefox webkit",
    "playwright:codegen": "playwright codegen",
    "playwright:show-report": "playwright show-report",
    "playwright:update-snapshots": "playwright test --project=visual --update-snapshots",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit",
    "check:full": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "validate:build": "npm run build && echo 'Build successful'"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@faker-js/faker": "^9.5.0",
    "@playwright/test": "^1.48.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.11.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^3.2.4"
  }
}
