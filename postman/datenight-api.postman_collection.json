              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status < 400', () => pm.expect(pm.response.code).to.be.below(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "/movie",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/movie", "host": ["{{baseUrl}}"], "path": ["movie"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status < 400', () => pm.expect(pm.response.code).to.be.below(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "/summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/summary", "host": ["{{baseUrl}}"], "path": ["summary"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status < 400', () => pm.expect(pm.response.code).to.be.below(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "/success",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/success", "host": ["{{baseUrl}}"], "path": ["success"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status < 400', () => pm.expect(pm.response.code).to.be.below(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "HTTP methods rejected where appropriate",
      "item": [
        {
          "name": "GET /__nonexistent__",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/__nonexistent_route__",
              "host": ["{{baseUrl}}"],
              "path": ["__nonexistent_route__"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.expect(pm.response.code).to.equal(404));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
