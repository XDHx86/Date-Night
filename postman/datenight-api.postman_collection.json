{
  "info": {
    "name": "Datenight API contract",
    "description": "Postman collection that pins the public contract of the Datenight dev server (TanStack Start). Use with `bunx newman run postman/datenight-api.postman_collection.json --env-var baseUrl=http://localhost:3000`.\n\nThe CI workflow `.github/workflows/api-tests.yml` invokes this collection against the live dev server (started by Playwright as the project's webServer) and fails the build if any status check is broader than 400.\n\n> The collection is intentionally conservative — only status, header and basic shape assertions. It should never depend on dynamic TMDb keys (the request handler is mocked inside the unit suite for that).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Landing page returns HTML",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 2xx or 3xx', () => pm.expect(pm.response.code).to.be.below(400));",
              "pm.test('Content-Type starts with text/html', () => pm.expect(pm.response.headers.get('Content-Type') || '').to.match(/text\\/html/));"
            ]
          }
        }
      ]
    },
    {
      "name": "Sitemap endpoint",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/sitemap.xml",
          "host": ["{{baseUrl}}"],
          "path": ["sitemap.xml"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.expect(pm.response.code).to.equal(200));",
              "pm.test('body declares urlset', () => pm.expect(pm.response.text()).to.include('<urlset'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Primary routes return 2xx",
      "item": [
        {
          "name": "/date",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/date", "host": ["{{baseUrl}}"], "path": ["date"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status < 400', () => pm.expect(pm.response.code).to.be.below(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "/time",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/time", "host": ["{{baseUrl}}"], "path": ["time"] }
          },
          "event": [
            {
