# Environment Variables
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here
# Optional Spotify integration
VITE_SPOTIFY_PLAYLIST_ID=your_spotify_playlist_id_here
VITE_RESEND_API_KEY=your_resend_api_key_here

# Love letter category (controls which set of letters is shown)
# Allowed values: default | birthday | anniversary | valentine
VITE_LOVE_LETTER_CATEGORY=default

# Love letter feature (enabled by default; set to "disabled" to remove the
# page, its nav entry, and all CTAs from the experience — direct /love-letter
# access redirects to the home page)
# VITE_LOVE_LETTER_FEATURE=disabled